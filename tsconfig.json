{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",

    "types": ["node"],

    "sourceMap": false,
    "declaration": false,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "index.ts",
    "Src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}